<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">5</defaultcontrol>
    <onload>CancelAlarm(osd_timeout,true)</onload>
    <controls>
        <include>PPI_Classic</include>

        <include>PPI_Modern</include>
		
        <control type="group">
            <visible>!Skin.HasSetting(ppi.classicMode) + !Skin.HasSetting(ppi.modernMode)</visible>
            <include content="DialogPictureInfo">
                <param name="header">[CAPITALIZE]$LOCALIZE[10116][/CAPITALIZE]</param>
                <param name="include_items">DialogProcessInfo_Items</param>
                <param name="include_picture">DialogPictureInfo_Video</param>
                <param name="dialog_size">Dimension_DialogMainMenu</param>
                <param name="dialog_right">693</param>
                <param name="itemline">$INFO[Player.FileNameAndPath]</param>
                <param name="include_itemline">!String.IsEmpty(Player.FileNameAndPath)</param>
            </include>
        </control>


    </controls>        
</window>
